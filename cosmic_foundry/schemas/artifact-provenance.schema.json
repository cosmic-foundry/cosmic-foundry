{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cosmic-foundry.github.io/cosmic-foundry/schemas/artifact-provenance.schema.json",
  "title": "Validation artifact provenance sidecar",
  "$comment": "A provenance sidecar records how one normalized validation artifact was produced. Distinct from validation-set build_plan, which records planning intent. Written by ValidationAdapter.build() implementations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "validation_set_id",
    "built_at",
    "adapter",
    "upstream",
    "artifact"
  ],
  "properties": {
    "validation_set_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "built_at": {
      "type": "string",
      "format": "date-time"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["script", "version"],
      "properties": {
        "script": { "$ref": "#/$defs/repo_relative_path" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog", "release", "retrieved_at"],
      "properties": {
        "catalog": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "release": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "retrieved_at": { "type": "string", "format": "date-time" },
        "content_hash": { "$ref": "#/$defs/sha256_hash" },
        "tables": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "url", "hash"],
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
            }
          }
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "content_hash", "row_count"],
      "properties": {
        "path": { "$ref": "#/$defs/repo_relative_path" },
        "content_hash": { "$ref": "#/$defs/sha256_hash" },
        "row_count": { "type": "integer", "minimum": 0 }
      }
    }
  },
  "$defs": {
    "repo_relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "sha256_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "value"],
      "properties": {
        "algorithm": { "const": "sha256" },
        "value": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
